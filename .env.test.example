# Configurações de Teste
# Copiar para .env.test e preencher com suas credenciais

# Google Gemini API
GEMINI_API_KEY=your-gemini-api-key-here

# Ambiente
ENVIRONMENT=test
DEBUG=true

# Banco de Dados
DATABASE_URL=sqlite:///:memory:
DATABASE_PROVIDER=sqlite

# Paths
DATA_DIR=./data
REPOS_DIR=./data/repos
PROCESSED_DIR=./data/processed
RAW_DIR=./data/raw
DB_DIR=./data/db

# ChromaDB
CHROMA_DB_PATH=./data/db/chroma
CHROMA_PERSIST=false

# GitHub (para testes)
GITHUB_API_KEY=your-github-token-here
GITHUB_USERNAME=akitaonrails

# Logging
LOG_LEVEL=DEBUG
LOG_FORMAT=json

# Timeouts
API_TIMEOUT=30
CONNECTION_TIMEOUT=10

# Feature Flags
ENABLE_CACHE=false
ENABLE_TELEMETRY=false
ENABLE_API_CACHING=false

# Teste específico
PYTEST_TIMEOUT=300
PYTEST_WORKERS=auto
